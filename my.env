# CrowdPulse AI — Environment Configuration
# ──────────────────────────────────────────
# DO NOT set ZONE_MAX_CAPACITY or ZONE_SAFE_CAPACITY here.
# Those are inferred automatically by YOLOv8-seg at startup.

# Zone identity
ZONE_NAME=Main Hall

# Fallback area — only used if camera/AI fails at startup
# Set this to the approximate real floor area of your space in m²
ZONE_AREA_M2=50

# Camera index (0 = default webcam, 1 = external camera)
CAMERA_INDEX=0

# Models
YOLO_MODEL_PATH=yolov8n.pt
YOLO_SEG_MODEL_PATH=yolov8n-seg.pt
YOLO_CONFIDENCE=0.4

# Server
FLASK_PORT=5001
DATABASE_PATH=crowd_data.db